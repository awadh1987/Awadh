rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allow database sync on companies
    match /companies/{companyId} {
      allow read, write: if true;
    }

    // Allow database sync on company clients
    match /companies/{companyId}/clients/{clientId} {
      allow read, write: if true;
    }

    // Allow database sync on company operations
    match /companies/{companyId}/operations/{operationId} {
      allow read, write: if true;
    }

    // Allow database sync on company invoices
    match /companies/{companyId}/invoices/{invoiceId} {
      allow read, write: if true;
    }

    // Allow database sync on company expenses
    match /companies/{companyId}/expenses/{expenseId} {
      allow read, write: if true;
    }

    // Allow database sync on company budgets
    match /companies/{companyId}/budgets/{budgetId} {
      allow read, write: if true;
    }

    // Allow database sync on company members
    match /companies/{companyId}/members/{memberId} {
      allow read, write: if true;
    }

    // Allow database sync on company audit logs
    match /companies/{companyId}/audit_logs/{logId} {
      allow read, write: if true;
    }

    // Allow the connection test document to read successfully
    match /test/{docId} {
      allow read, write: if true;
    }

    // Catch-all safety net (default-deny catch-all)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
